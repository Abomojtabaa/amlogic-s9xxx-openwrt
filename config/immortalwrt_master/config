# دعم المعالج والجهاز
CONFIG_TARGET_amlogic=y
CONFIG_TARGET_amlogic_meson64=y
CONFIG_TARGET_amlogic_meson64_DEVICE_amlogic_p212=y

# تعريفات USB Ethernet (لحل مشكلة WAN)
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-asix=y
CONFIG_PACKAGE_kmod-usb-net-asix-ax88179=y
CONFIG_PACKAGE_kmod-usb-net-rtl8150=y
CONFIG_PACKAGE_kmod-usb-net-rtl8152=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y

# أدوات التحكم في الطاقة والمنفذ
CONFIG_PACKAGE_usbutils=y
CONFIG_PACKAGE_ethtool=y

# إزالة v2rayA وأي تطبيقات ثقيلة (للاستقرار)
# CONFIG_PACKAGE_luci-app-v2raya is not set
# CONFIG_PACKAGE_v2raya is not set

# واجهة التحكم LuCI واللغة العربية (اختياري)
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-ar=y
CONFIG_PACKAGE_luci-theme-argon=y
